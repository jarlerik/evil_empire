# Supabase project (same project as mobile in v1 — staging and prod share it).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of the peaktrack-api Lambda. In local dev this points at the
# `pnpm dev:api` host (default http://localhost:3001). In staging/prod this
# is the Function URL or its CloudFront alias.
VITE_API_BASE_URL=http://localhost:3001

# Set to "1" to expose the hidden /coach surface that exercises POST
# /api/coach/prompt. The route is intentionally not added to the sidebar
# nav; reach it via /coach when enabled. Production builds should leave
# this unset until the coach UX is finalised.
VITE_COACH_ENABLED=

ALPACA_KEY_ID=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_PAPER=true

# Scanner
MIN_GAP_PCT=5
PREF_GAP_PCT=20
MIN_PRICE=1.00
MAX_PRICE=20.00
MAX_FLOAT=20000000
MIN_REL_VOLUME=5
SCAN_INTERVAL_MIN=15    # 0 = scan once, >0 = re-scan every N minutes during pre-market

# Risk
RR_RATIO=2
RISK_PER_TRADE_PCT=1.5
MAX_DAILY_LOSS_PCT=10
MAX_CONSEC_LOSSES=3

# Trading
TIME_STOP_BARS=5
TRAILING_STOP_PCT=1.5
STRATEGIES=all

{
  "name": "@evil-empire/warrior-trading",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:dashboard": "vite",
    "dev:autotrader": "bun run src/index.ts & vite & wait",
    "build": "bun build src/index.ts --outdir dist --target bun",

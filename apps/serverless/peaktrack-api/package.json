{
  "name": "@evil-empire/peaktrack-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/server.ts",
    "bundle": "node scripts/bundle.mjs",
    "build:infra": "sam build",
    "build": "pnpm bundle && pnpm build:infra",
    "deploy:staging": "pnpm bundle && sam build && sam deploy --config-env staging",
    "deploy:prod": "pnpm bundle && sam build && sam deploy --config-env prod",
    "smoke": "sam local start-api",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@evil-empire/peaktrack-services": "workspace:*",
    "@evil-empire/types": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@evil-empire/eslint-config": "workspace:*",
    "@evil-empire/typescript-config": "workspace:*",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2",
    "vitest": "^2.1.0"
  }
}

# Local dev (`pnpm dev:api`). Required vars are checked at startup —
# missing values fail fast with a clear error rather than 500-ing later.

# Supabase project URL. Used to derive the JWKS discovery URL
# (${SUPABASE_URL}/auth/v1/.well-known/jwks.json) for asymmetric token
# verification. Copy from Supabase dashboard → Project Settings → API → URL.
# No trailing slash.
SUPABASE_URL=

# Comma-separated CORS allowlist. Defaults already cover localhost / null /
# capacitor://localhost in development; add your machine's LAN IP here when
# testing Expo Go on a physical phone (e.g.,
# CORS_ALLOWED_ORIGINS=http://192.168.1.42:8081).
CORS_ALLOWED_ORIGINS=

# AI provider secret used by /api/coach/prompt. Optional locally — when
# unset, the coach falls back to a stub provider that echoes the last user
# message so the SSE plumbing is still exercised end-to-end. Production
# stacks must set this via SAM `AnthropicApiKey` parameter (NoEcho).
ANTHROPIC_API_KEY=

# Override port for the local dev server.
PORT=3001

NODE_ENV=development

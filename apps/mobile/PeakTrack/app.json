{
  "expo": {
    "name": "PeakTrack",
    "slug": "peaktrack",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/peaktrack-1024.png",
    "scheme": "peaktrack",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#000000",
      "bundleIdentifier": "dev.vaikia.peaktrack",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      ["expo-audio",
        {
          "enableBackgroundPlayback": true,
          "playWhenInactive": true,
          "playWhenBackgrounded": true

        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5dbb60fc-11f8-4782-92b6-6a65358b7196"
      }
    }
  }
}

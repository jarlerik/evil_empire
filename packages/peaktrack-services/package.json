{
  "name": "@evil-empire/peaktrack-services",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@evil-empire/parsers": "workspace:*",
    "@evil-empire/types": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@evil-empire/eslint-config": "workspace:*",
    "@evil-empire/typescript-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "eslint": "^9.0.0",
    "jest": "^29.2.1",
    "ts-jest": "^29.2.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.2"
  }
}
